# PachaNova v2.0 - Environment Variables

# Configuración Base de Datos (Neon Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/pachanova"

# Autenticación (NextAuth v5)
AUTH_SECRET="super-secret-auth-key-pachanova-2026"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Pagos (MercadoPago)
MERCADOPAGO_ACCESS_TOKEN="TEST-xxxxx"
MERCADOPAGO_WEBHOOK_SECRET="yyyyy"

# Blockchain y Web3
NEXT_PUBLIC_RPC_URL="http://127.0.0.1:8545" # Anvil Local
NEXT_PUBLIC_CHAIN_ID="31337"

# Integración AI
GEMINI_API_KEY="AIzaSy..."
