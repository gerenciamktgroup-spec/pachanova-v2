# PachaNova v2.0 - Demo Local Secret Overrides
# DO NOT COMMIT THIS FILE IF IT CONTAINS REAL SECRETS.
# Rename to .env.demo.local to override .env.demo variables

DEMO_MODE=true
DEMO_PROFILE=sandbox
PAYMENTS_EXTERNAL_ENABLED=true

# MercadoPago Sandbox Config
MERCADOPAGO_ENV=sandbox
MERCADOPAGO_PUBLIC_KEY=TEST_placeholder
MERCADOPAGO_ACCESS_TOKEN=TEST_placeholder
MERCADOPAGO_WEBHOOK_SECRET=placeholder
MERCADOPAGO_WEBHOOK_URL=https://example-tunnel.ngrok-free.app/api/mercadopago/webhook
MERCADOPAGO_CURRENCY=USD
MP_WEBHOOK_ALLOW_UNSIGNED=false

APP_BASE_URL=https://example-tunnel.ngrok-free.app
NEXTAUTH_URL=https://example-tunnel.ngrok-free.app
