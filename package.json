{
  "name": "pachanova-v2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @pachanova/database run db:generate",
    "db:migrate": "pnpm --filter @pachanova/database run db:migrate",
    "contracts:test": "pnpm --filter @pachanova/contracts run test",
    "demo:db:up": "docker compose -f docker-compose.demo.yml up -d",
    "demo:db:down": "docker compose -f docker-compose.demo.yml down",
    "demo:db:migrate": "pnpm --filter @pachanova/database run demo:migrate",
    "demo:db:seed": "pnpm --filter @pachanova/database run demo:seed",
    "demo:up": "pnpm run demo:db:up",
    "demo:down": "pnpm run demo:db:down",
    "demo:reset": "pnpm --filter @pachanova/database run demo:reset && pnpm run demo:db:migrate && pnpm run demo:db:seed",
    "demo:doctor": "tsx scripts/demo/doctor.ts",
    "demo:acceptance": "tsx scripts/demo/acceptance.ts",
    "demo:showcase": "pnpm run demo:up && pnpm run demo:reset && pnpm run dev",
    "demo:export-report": "tsx scripts/demo/exportReport.ts",
    "demo:health": "tsx scripts/demo-health-check.ts",
    "mp:sandbox:preflight": "tsx scripts/mercadopago-sandbox-preflight.ts",
    "mp:sandbox:smoke": "tsx scripts/mercadopago-sandbox-smoke.ts",
    "test:demo": "vitest run tests/demo/unit.test.tsx",
    "test:e2e:demo": "playwright test -c tests/demo/playwright.config.ts",
    "demo:start": "pnpm --filter web run dev",
    "demo:scenario:happy": "pnpm --filter @pachanova/database run demo:scenario:happy",
    "demo:scenario:rejected-payment": "pnpm --filter @pachanova/database run demo:scenario:rejected",
    "demo:scenario:duplicate-webhook": "pnpm --filter @pachanova/database run demo:scenario:duplicate",
    "demo:scenario:kyc-pending": "pnpm --filter @pachanova/database run demo:scenario:kyc-pending",
    "demo:scenario:contract-connected": "pnpm --filter @pachanova/database run demo:scenario:connected",
    "demo:scenario:contract-simulated": "pnpm --filter @pachanova/database run demo:scenario:simulated",
    "demo:contracts:anvil": "pnpm --filter @pachanova/contracts run demo:anvil",
    "demo:contracts:deploy": "pnpm --filter @pachanova/contracts run demo:deploy",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "turbo": "latest",
    "typescript": "^5.0.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.11.0"
}
