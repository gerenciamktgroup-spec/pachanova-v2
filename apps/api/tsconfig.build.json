{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@pachanova/database": ["../../packages/database/src/index.ts"],
      "@pachanova/database/*": ["../../packages/database/src/*"],
      "@pachanova/integrations": ["../../packages/integrations/src/index.ts"],
      "@pachanova/integrations/*": ["../../packages/integrations/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/database/src/**/*",
    "../../packages/integrations/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../packages/database/src/seed/**/*"
  ]
}
