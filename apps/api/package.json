{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json && node -e \"const fs=require('fs');const p='dist/apps/api/src';if(fs.existsSync(p)){fs.cpSync(p,'dist',{recursive:true});fs.rmSync('dist/apps',{recursive:true});fs.rmSync('dist/packages',{recursive:true,force:true})}\""
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@pachanova/database": "workspace:*",
    "@pachanova/integrations": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.12",
    "typescript": "^5",
    "tsx": "^4.21.0",
    "@types/node": "^20"
  },
  "devDependencies": {}
}
